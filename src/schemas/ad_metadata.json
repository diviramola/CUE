{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ad Metadata",
  "type": "object",
  "required": ["id", "advertiser", "platform", "format", "duration_seconds", "url", "source", "date_found", "vertical", "region", "description", "why_included", "tags", "deconstructed"],
  "properties": {
    "id": { "type": "string", "pattern": "^ad_\\d{3,}$" },
    "advertiser": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "enum": ["Meta", "YouTube", "Instagram", "LinkedIn", "TV", "OTT", "Other"] },
    "format": { "type": "string", "enum": ["Reel", "In-Feed Video", "Story", "Pre-Roll", "Mid-Roll", "TVC", "Bumper", "Other"] },
    "duration_seconds": { "type": "integer", "minimum": 1 },
    "language": { "type": "string" },
    "url": { "type": "string" },
    "source": { "type": "string", "enum": ["meta_ad_library", "web_search", "manual", "youtube_transparency"] },
    "date_found": { "type": "string", "format": "date" },
    "date_published": { "type": "string" },
    "vertical": { "type": "string" },
    "region": { "type": "string" },
    "tier": { "type": ["string", "null"], "enum": ["exceptional", "strong", "reference", null] },
    "tier_notes": { "type": "string" },
    "description": { "type": "string", "minLength": 10 },
    "why_included": { "type": "string", "minLength": 10 },
    "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "deconstructed": { "type": "boolean" }
  },
  "additionalProperties": false
}
